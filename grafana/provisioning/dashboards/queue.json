{
  "id": null,
  "uid": "pizza-queue",
  "title": "Pizza Order Queue",
  "tags": ["pizza", "queue"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pending",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "pizza-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "pizza-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Pending\" FROM internal.orders WHERE status = 'pending'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Processing",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "pizza-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "pizza-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Processing\" FROM internal.orders WHERE status = 'processing'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "orange", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Processed Today",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "pizza-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "pizza-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Processed Today\" FROM internal.orders WHERE status = 'processed' AND created_at >= CURRENT_DATE AT TIME ZONE 'Australia/Sydney'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cancelled Today",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "pizza-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "pizza-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Cancelled Today\" FROM internal.orders WHERE status = 'cancelled' AND created_at >= CURRENT_DATE AT TIME ZONE 'Australia/Sydney'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Orders Placed Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "pizza-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "pizza-postgres" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('second', created_at) AS time,\n  COUNT(*) AS \"Orders Placed\"\nFROM internal.orders\nWHERE $__timeFilter(created_at)\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Queue Depth by Store",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "pizza-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "pizza-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  s.name AS \"Store\",\n  SUM(CASE WHEN o.status = 'pending'    THEN 1 ELSE 0 END) AS \"Pending\",\n  SUM(CASE WHEN o.status = 'processing' THEN 1 ELSE 0 END) AS \"Processing\",\n  SUM(CASE WHEN o.status = 'processed'  THEN 1 ELSE 0 END) AS \"Processed\",\n  SUM(CASE WHEN o.status = 'cancelled'  THEN 1 ELSE 0 END) AS \"Cancelled\",\n  COUNT(*) AS \"Total\"\nFROM internal.orders o\nJOIN internal.stores s ON s.id = o.store_id\nGROUP BY s.name\nORDER BY \"Pending\" DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Pending" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 50 },
                    { "color": "red", "value": 200 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Pending" }]
      }
    },

    {
      "id": 100,
      "type": "row",
      "title": "DB Telemetry",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Cache Hit Ratio",
      "description": "Percentage of block reads served from shared_buffers instead of disk. Below 99% suggests memory pressure.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 21 },
      "datasource": { "type": "postgres", "uid": "pizza-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "pizza-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(100.0 * blks_hit / NULLIF(blks_hit + blks_read, 0), 2) AS \"Cache Hit %\"\nFROM pg_stat_database WHERE datname = 'pizza'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 21 },
      "datasource": { "type": "postgres", "uid": "pizza-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "pizza-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Active Connections\"\nFROM pg_stat_activity\nWHERE datname = 'pizza' AND state = 'active'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Database Size",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 21 },
      "datasource": { "type": "postgres", "uid": "pizza-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "pizza-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT pg_database_size('pizza') AS \"Database Size\"",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Lock Conflicts",
      "description": "Queries currently waiting to acquire a lock.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 21 },
      "datasource": { "type": "postgres", "uid": "pizza-postgres" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "pizza-postgres" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Lock Conflicts\"\nFROM pg_stat_activity\nWHERE datname = 'pizza' AND wait_event_type = 'Lock'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Transactions per Second",
      "description": "Committed + rolled-back transactions/sec from pg_stat_database.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "pizza-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pizza-prometheus" },
          "expr": "rate(pg_stat_database_xact_commit{datname=\"pizza\"}[30s]) + rate(pg_stat_database_xact_rollback{datname=\"pizza\"}[30s])",
          "legendFormat": "TPS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Connections by State",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "pizza-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pizza-prometheus" },
          "expr": "pg_stat_activity_count{datname=\"pizza\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },

    {
      "id": 200,
      "type": "row",
      "title": "Container Resources (db)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "collapsed": false
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "CPU Usage",
      "description": "CPU cores consumed by the db container (cadvisor).",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "pizza-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pizza-prometheus" },
          "expr": "rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"db\"}[30s]) * 100",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Memory Usage",
      "description": "RSS memory consumed by the db container (cadvisor).",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "pizza-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pizza-prometheus" },
          "expr": "container_memory_rss{container_label_com_docker_compose_service=\"db\"}",
          "legendFormat": "RSS Memory",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Network I/O",
      "description": "Bytes received and transmitted by the db container per second (cadvisor).",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "pizza-prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "pizza-prometheus" },
          "expr": "rate(container_network_receive_bytes_total{container_label_com_docker_compose_service=\"db\"}[30s])",
          "legendFormat": "RX",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "pizza-prometheus" },
          "expr": "rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service=\"db\"}[30s])",
          "legendFormat": "TX",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    }
  ]
}
